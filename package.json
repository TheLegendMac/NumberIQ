{
  "name": "numberiq",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Local-first Florida Lottery analytics workbench. Personal use only.",
  "workspaces": ["shared", "server", "web"],
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "start": "npm run start --workspace server",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --pretty"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
